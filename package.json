{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "oc-plugin-cortana",
  "version": "0.1.0",
  "type": "module",
  "description": "Cortana + Weapon TUI themes for OpenCode (warm Gruvbox & cool blue energy)",
  "exports": {
    "./tui": {
      "import": "./tui.tsx",
      "config": {
        "enabled": true,
        "set_theme": true,
        "sidebar": true
      }
    }
  },
  "engines": {
    "opencode": ">=1.3.13"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*",
    "@opentui/core": "*",
    "@opentui/solid": "*",
    "solid-js": "*"
  }
}
